# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/appointbot

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Multi-tenant: default business ID (used when no subdomain routing) ───────
DEFAULT_BUSINESS_ID=1

# ─── Business contact (shown when user asks "how do I reach you?") ────────────
#BUSINESS_CONTACT_PHONE=+91XXXXXXXXXX

# ─── LLM — Groq (recommended: fast cloud inference, free tier available) ──────
# Get your key at https://console.groq.com/keys
# If not set, falls back to local Ollama automatically.
#GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#GROQ_MODEL=llama-3.3-70b-versatile

# ─── Ollama (local LLM fallback — used only when GROQ_API_KEY is not set) ─────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────
# Configure this phone number as the webhook sender in your Meta app:
#   - Callback URL:  https://your-domain.com/webhook
#   - Verify token:  WHATSAPP_VERIFY_TOKEN
#   - Permissions:   whatsapp_business_messaging, whatsapp_business_management
#WHATSAPP_ACCESS_TOKEN=EAAB...your_long_lived_access_token
#WHATSAPP_PHONE_NUMBER_ID=123456789012345
#WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
#WHATSAPP_VERIFY_TOKEN=change_this_verify_token
#WHATSAPP_API_VERSION=v21.0

# Optional: Embedded signup automation (per-business connect flow)
#WHATSAPP_APP_ID=123456789012345
#WHATSAPP_APP_SECRET=your_meta_app_secret
#WHATSAPP_EMBEDDED_CONFIG_ID=your_whatsapp_embedded_config_id
#WHATSAPP_EMBEDDED_REDIRECT_URL=https://your-domain.com/api/whatsapp-connect/callback

# ─── WhatsApp Reminder Template ───────────────────────────────────────────────
# Required to send appointment reminders outside the 24-hour conversation window.
# Without this, reminders for appointments booked >24 hours in advance will fail
# with Meta error 131026 ("more than 24 hours since customer last replied").
#
# Steps to enable:
#   1. Go to Meta Business Manager → WhatsApp Manager → Message Templates
#   2. Create a new "Utility" category template (e.g. named "appointbot_reminder")
#   3. Template body should use 5 variables:
#      "Hi {{1}}, reminder from {{2}}. Your {{3}} appointment with {{4}} is on {{5}}. Reply CANCEL to cancel."
#   4. Wait for Meta approval (usually a few minutes for Utility templates)
#   5. Set the approved template name below
#
#WHATSAPP_REMINDER_TEMPLATE_NAME=appointbot_reminder
#WHATSAPP_REMINDER_TEMPLATE_LANG=en
