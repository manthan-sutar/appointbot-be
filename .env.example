# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local:    postgresql://user:password@localhost:5432/appointbot
# Supabase: copy "Transaction pooler" URI from Supabase → Settings → Database
DATABASE_URL=postgresql://user:password@localhost:5432/appointbot

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Public backend URL used in dashboard widget embed snippets (optional; if unset, the
# server derives HTTPS from the incoming request, or uses RENDER_EXTERNAL_URL on Render).
# Set this in production if embeds must always point at a fixed host.
# PUBLIC_BACKEND_URL=https://appointbot-be.onrender.com
# Alias: WIDGET_PUBLIC_URL (same meaning)
# Internal / generic base (may be localhost in dev)
BACKEND_URL=http://localhost:3000
# In production set this to your Vercel frontend URL, e.g. https://appointbot.vercel.app
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated extra CORS origins (e.g. http://localhost:5173 when the deployed
# backend must accept requests from local Vite while FRONTEND_URL is your production URL).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret
# Self-service signup API. Leave unset or false in production (use Request Demo flow).
# Set to true only for local/dev if you need to create accounts without admin.
# ALLOW_PUBLIC_SIGNUP=true

# ─── Multi-tenant ─────────────────────────────────────────────────────────────
# Default business ID used when no per-business routing is in place
DEFAULT_BUSINESS_ID=1

# ─── Business contact ─────────────────────────────────────────────────────────
# Shown when a customer asks "how do I reach you?"
#BUSINESS_CONTACT_PHONE=+91XXXXXXXXXX

# ─── LLM — Groq (recommended) ─────────────────────────────────────────────────
# Free tier available at https://console.groq.com/keys
# If not set, falls back to local Ollama automatically.
#GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#GROQ_MODEL=llama-3.3-70b-versatile

# ─── Ollama (local LLM fallback) ──────────────────────────────────────────────
# Only used when GROQ_API_KEY is not set.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Configure in Meta Developer Console → Your App → WhatsApp → Configuration
#
# REQUIRED — any string you choose; must match what you set in Meta webhook config
WHATSAPP_VERIFY_TOKEN=change_this_to_any_random_string
#
# OPTIONAL — defaults to v21.0 if not set
#WHATSAPP_API_VERSION=v21.0
#
# OPTIONAL FALLBACK — only needed if you want a hardcoded default/test number.
# Businesses that connect via Embedded Signup get their own credentials stored
# in the database automatically — these global vars are not used for them.
#WHATSAPP_ACCESS_TOKEN=EAAB...your_long_lived_access_token
#WHATSAPP_PHONE_NUMBER_ID=123456789012345
#WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345

# ─── WhatsApp Embedded Signup (per-business connect flow) ─────────────────────
# REQUIRED — enables the "Connect WhatsApp" button in the onboarding dashboard.
# Set up at Meta Developer Console → Your App → WhatsApp → Embedded Signup.
#WHATSAPP_APP_ID=123456789012345
#WHATSAPP_APP_SECRET=your_meta_app_secret
#WHATSAPP_EMBEDDED_CONFIG_ID=your_whatsapp_embedded_config_id
#WHATSAPP_EMBEDDED_REDIRECT_URL=https://your-backend.com/api/whatsapp-connect/callback

# ─── WhatsApp Reminder Template ───────────────────────────────────────────────
# Required to send reminders outside the 24-hour customer conversation window.
# Without this, reminders for appointments booked >24 h in advance will fail
# (Meta error 131026). Steps:
#   1. Meta Business Manager → WhatsApp Manager → Message Templates
#   2. Create a "Utility" template, e.g. named "appointbot_reminder", body:
#      "Hi {{1}}, reminder from {{2}}. Your {{3}} appointment with {{4}} is on {{5}}. Reply CANCEL to cancel."
#   3. Wait for Meta approval (usually minutes for Utility templates)
#   4. Set the approved template name below
#WHATSAPP_REMINDER_TEMPLATE_NAME=appointbot_reminder
#WHATSAPP_REMINDER_TEMPLATE_LANG=en

# ─── Campaign Auto-Retry ──────────────────────────────────────────────────────
# Failed campaign sends are retried by scheduler with backoff (15m/30m/60m).
# You can tune max attempts (1..10).
#CAMPAIGN_AUTO_RETRY_MAX_ATTEMPTS=3
# Hard cap of recipients processed per campaign send (1..10000).
#CAMPAIGN_MAX_RECIPIENTS_PER_SEND=1000

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# Set PAYMENT_PROVIDER=none to disable payments entirely.
# Get keys at https://dashboard.razorpay.com/app/keys
PAYMENT_PROVIDER=none
#PAYMENT_PROVIDER=razorpay
#RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
#RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
#RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Razorpay Subscription Plan IDs (create these in Razorpay Dashboard → Products → Plans)
#RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxx
#RAZORPAY_BUSINESS_PLAN_ID=plan_xxxxxxxxxxxx
